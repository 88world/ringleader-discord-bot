{
  "name": "@ringleader/bot",
  "version": "1.0.0",
  "description": "Ringleader Discord bot service",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "prestart": "prisma generate",
    "start": "node dist/index.js",
    "start:railway": "prisma migrate deploy && prisma generate && node dist/index.js",
    "register": "tsx src/registerCommands.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "discord-api-types": "^0.38.48",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
